UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    local k = input.KeyCode.Name

    -- Silent Aim
    local saKey = keybinds["Silent Target"] or "C"
    if k == saKey then
        if sa["Selection"] == "Target" then
            if SelectedTarget then SelectedTarget = nil; CurrentTarget = nil; SilentAimActive = false
            else
                local t = FindClosestToMouse(true)
                if t then SelectedTarget = t; CurrentTarget = t; SilentAimActive = true end
            end
        else
            SilentAimActive = not SilentAimActive
            if not SilentAimActive then CurrentTarget = nil end
        end
    end

    -- Speed
    if (cm["Speed"] or {})["Enabled"] and k == (keybinds["Speed"] or "V") then
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            if not SpeedEnabled then BaseSpeed = 16; SpeedEnabled = true
            else hum.WalkSpeed = BaseSpeed; SpeedEnabled = false end
        end
    end

    -- Trigger Bot
    local tbKey = keybinds["Trigger Bot"] or "V"
    if k == tbKey then
        local mode = ((tb["Activation"] or {})["Type"] or "Toggle")
        if mode == "Toggle" then TriggerBotActive = not TriggerBotActive
        else TriggerBotActive = true end
    end

    -- Jump
    if (cm["Jump"] or {})["Enabled"] and k == (keybinds["Jump"] or "Y") then
        SuperJumpActive = not SuperJumpActive
    end

    -- Mouse down
    if input.UserInputType == Enum.UserInputType.MouseButton1 then isMouseDown = true end
end)

UserInputService.InputEnded:Connect(function(input, processed)
    if processed then return end
    local k = input.KeyCode.Name
    local tbKey = keybinds["Trigger Bot"] or "V"
    if k == tbKey and ((tb["Activation"] or {})["Type"] or "Toggle") == "Hold" then
        TriggerBotActive = false
    end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then isMouseDown = false end
end)

-- ============================================================================
-- TRIGGER BOT
-- ============================================================================
local function RunTriggerBot()
    if not tb["Enabled"] or not TriggerBotActive then return end
    if tick() - LastTriggerShot < (tb["Delay"] or 0) then return end
    if not CurrentTarget or not CurrentTarget.Character then return end
    if PlayerDead(CurrentTarget) or PlayerKnocked(CurrentTarget) then return end
    local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    tool:Activate(); LastTriggerShot = tick()
end

