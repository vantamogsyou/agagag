-- ============================================================================
-- MAIN HEARTBEAT
-- ============================================================================
RunService.Heartbeat:Connect(function()
    UpdateTarget()
    RunTriggerBot()
    RefreshESP()

    -- Speed
    local spd = cm["Speed"] or {}
    if spd["Enabled"] and SpeedEnabled then
        local char = LocalPlayer.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if hum then
            local cond = spd["Conditions"] or {}
            local mult = (cond["Normal"] or {})["Multiplier"] or 2.5
            if hum.WalkSpeed ~= BaseSpeed * mult then hum.WalkSpeed = BaseSpeed * mult end
        end
        if cm["Anti Fling"] ~= false and hrp then
            local vel = hrp.AssemblyLinearVelocity or hrp.Velocity
            if abs(vel.Y) > 50 then hrp.AssemblyLinearVelocity = V3(vel.X, 0, vel.Z) end
        end
    elseif not SpeedEnabled then
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.WalkSpeed ~= 16 then hum.WalkSpeed = 16 end
    end

    -- Super Jump
    local jmp = cm["Jump"] or {}
    if jmp["Enabled"] and SuperJumpActive then
        local char = LocalPlayer.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if hum and hrp and not SuperJumpCooldown then
            if hum:GetState() == Enum.HumanoidStateType.Landed or hum.FloorMaterial ~= Enum.Material.Air then
                SuperJumpCooldown = true
                local mult = ((jmp["Conditions"] or {})["Normal"] or {})["Multiplier"] or 4
                hrp.AssemblyLinearVelocity = V3(hrp.AssemblyLinearVelocity.X, mult * 100, hrp.AssemblyLinearVelocity.Z)
                task.delay(0.1, function() SuperJumpCooldown = false end)
            end
        end
    end

    -- Target tracer
    if CurrentTarget and CurrentTarget.Character then
        local head = CurrentTarget.Character:FindFirstChild("Head")
        if head and not PlayerDead(CurrentTarget) then
            local hp, on = Camera:WorldToViewportPoint(head.Position)
            if on and hp.Z > 0 then
                local mp = UserInputService:GetMouseLocation()
                TargetTracer.From = V2(mp.X, mp.Y); TargetTracer.To = V2(hp.X, hp.Y)
                TargetTracer.Visible = SilentAimActive
            else TargetTracer.Visible = false end
        else TargetTracer.Visible = false end
    else TargetTracer.Visible = false end

    -- Infinite Range
    if InfRangeActive then
        local char = LocalPlayer.Character
        local tool = char and char:FindFirstChildOfClass("Tool")
        if tool then
            local range = (wm["Bullet Distance"] or {})["Range"] or 900000000
            for _, prop in ipairs({"Range","MaxRange","FireRange","Distance","MaxDistance"}) do
                local v = tool:FindFirstChild(prop)
                if v and (v:IsA("NumberValue") or v:IsA("IntValue")) then v.Value = range end
                local gc = tool:FindFirstChild("Configuration") or tool:FindFirstChild("GunConfig")
                if gc then local r = gc:FindFirstChild(prop); if r then r.Value = range end end
            end
        end
    end
end)
