-- KEY SYSTEM
-- ============================================================================
do
    local userKey = tostring(core["Script Key"] or "")
    assert(userKey ~= "", "[Vanta] No key set in config.")

    local hwid = tostring(game:GetService("RbxAnalyticsService"):GetClientId())
    local API  = "https://bypass-production-954a.up.railway.app/check"

    local ok, res = pcall(function()
        return game:HttpGet(API .. "?key=" .. userKey .. "&hwid=" .. hwid)
    end)

    local valid  = false
    local reason = "Invalid key"
    if ok and res then
        pcall(function()
            local data = game:GetService("HttpService"):JSONDecode(res)
            valid  = data.valid
            reason = data.reason or reason
        end)
    end

    if not valid then
        game:GetService("Players").LocalPlayer:Kick("Vanta — " .. reason)
        return
    end
end

