local CachedPing = 0.05
local LastPingT  = 0
local function GetPing()
    local now = tick()
    if now - LastPingT > 2 then
        LastPingT = now
        pcall(function()
            CachedPing = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
        end)
        if CachedPing < 0.01 then CachedPing = 0.03 end
    end
    return CachedPing
end

