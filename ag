local function AddESP(player)
    if player == LocalPlayer then return end
    local e = {player = player, nameTag = Drawing.new("Text")}
    e.nameTag.Size = 14; e.nameTag.Center = true; e.nameTag.Outline = true
    e.nameTag.Font = Drawing.Fonts.UI
    e.nameTag.Color   = (espCfg["Name"] or {})["Color"]        or Color3.fromRGB(255,255,255)
    e.nameTag.Visible = false; e.nameTag.ZIndex = 1000
    ESPLabels[player.UserId] = e
end

local function RemoveESP(player)
    local e = ESPLabels[player.UserId]
    if e then pcall(function() e.nameTag:Remove() end); ESPLabels[player.UserId] = nil end
end

local function RefreshESP()
    if not espCfg["Enabled"] then
        for _, e in pairs(ESPLabels) do e.nameTag.Visible = false end
        return
    end
    for uid, e in pairs(ESPLabels) do
        local p = e.player
        if not p or not p.Parent then
            e.nameTag.Visible = false; pcall(function() e.nameTag:Remove() end)
            ESPLabels[uid] = nil; continue
        end
        if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then
            e.nameTag.Visible = false; continue
        end
        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then e.nameTag.Visible = false; continue end
        local lp, on = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position - V3(0,3,0))
        if on and lp.Z > 0 then
            e.nameTag.Position = V2(lp.X, lp.Y + 15)
            local dn = p.DisplayName
            e.nameTag.Text = (dn and dn ~= "") and dn or p.Name
            local isTarget = p == CamLockTarget or p == CurrentTarget or p == SelectedTarget
            e.nameTag.Color = isTarget
                and ((espCfg["Name"] or {})["Target Color"] or Color3.fromRGB(255,0,0))
                or  ((espCfg["Name"] or {})["Color"]        or Color3.fromRGB(255,255,255))
            e.nameTag.Visible = true
        else e.nameTag.Visible = false end
    end
end

for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then AddESP(p) end end
