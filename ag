-- ============================================================================
-- HELPERS
-- ============================================================================
local function PlayerDead(p)
    if not p.Character then return true end
    local be = p.Character:FindFirstChild("BodyEffects")
    if be then
        local d = be:FindFirstChild("Dead"); if d and d.Value then return true end
        local k = be:FindFirstChild("K.O");  if k and k.Value then return true end
    end
    local h = p.Character:FindFirstChildOfClass("Humanoid")
    return h and h.Health <= 0
end

local function PlayerKnocked(p)
    if not checks["Knocked"] then return false end
    if not p.Character then return false end
    local be = p.Character:FindFirstChild("BodyEffects")
    if be then local k = be:FindFirstChild("K.O"); if k and k.Value then return true end end
    return false
end

local function HoldingKnife()
    if not checks["Knife"] then return false end
    local char = LocalPlayer.Character; if not char then return false end
    local tool = char:FindFirstChildOfClass("Tool")
    return tool and tool.Name == "[Knife]"
end

local function IsChatOpen() return UserInputService:GetFocusedTextBox() ~= nil end

local function CanSee(part)
    if not checks["Visible"] then return true end
    if not part or not part.Parent then return false end
    RayParams.FilterDescendantsInstances = {LocalPlayer.Character, part.Parent}
    local result = Workspace:Raycast(Camera.CFrame.Position, part.Position - Camera.CFrame.Position, RayParams)
    return result == nil or result.Instance:IsDescendantOf(part.Parent)
end

local function GetClosestBodyPart(char, mp)
    local best, bd = nil, huge
    for _, name in ipairs({"Head","HumanoidRootPart","UpperTorso","LowerTorso"}) do
        local part = char:FindFirstChild(name)
        if part then
            local sp, on = Camera:WorldToViewportPoint(part.Position)
            local d = (not on or sp.Z <= 0) and 999999 or sqrt((sp.X-mp.X)^2+(sp.Y-mp.Y)^2)
            if d < bd then bd = d; best = part end
        end
    end
    return best
end

local function GetTargetPart(char, mp)
    local hp = (sa["Hit Location"] or {})["Hit Part"] or "Closest Point"
    if hp == "Head"          then return char:FindFirstChild("Head")
    elseif hp == "HumanoidRootPart" then return char:FindFirstChild("HumanoidRootPart")
    elseif hp == "UpperTorso" then return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    else return GetClosestBodyPart(char, mp) end
end

local function IsAirborne(char)
    if not char then return false end
    local h = char:FindFirstChildOfClass("Humanoid"); if not h then return false end
    local s = h:GetState()
    if s == Enum.HumanoidStateType.Freefall or s == Enum.HumanoidStateType.Flying or s == Enum.HumanoidStateType.Jumping then return true end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    return hrp and abs((hrp.AssemblyLinearVelocity or hrp.Velocity).Y) > 5
end

local function GetPredicted(part, char)
    if not part or not part:IsA("BasePart") then return part.Position end
    local vel  = part.AssemblyLinearVelocity or part.Velocity or V3(0,0,0)
    local pred = sa["Prediction"] or {}
    return part.Position + V3(
        vel.X * (pred["X"] or 0),
        vel.Y * (pred["Y"] or 0),
        vel.Z * (pred["Z"] or 0)
    )
end

-- ============================================================================
-- TARGET FINDING
-- ============================================================================
local function FindClosestToMouse(ignoreFOV)
    if HoldingKnife() then return nil end
    local mp   = UserInputService:GetMouseLocation()
    local fov  = sa["FOV"] or {}
    local fovOn = fov["Enabled"] and not ignoreFOV
    local fovSz = fovOn and (fov["Show FOV"] and 20 or 20) or huge
    -- use actual FOV size from config
    if fovOn then
        local t = fov["Type"] or "2D"
        if t == "2D" then fovSz = ((fov["2D"] or {})["X"] or 20)
        else fovSz = ((fov["3D"] or {})["X"] or 12) end
    end
    local best, bd = nil, huge
    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer or not p.Character then continue end
        local head = p.Character:FindFirstChild("Head"); if not head then continue end
        if PlayerDead(p) or PlayerKnocked(p) then continue end
        local sp, on = Camera:WorldToViewportPoint(head.Position)
        if not on or sp.Z <= 0 then continue end
        local d = sqrt((mp.X-sp.X)^2+(mp.Y-sp.Y)^2)
        if fovOn and d > fovSz then continue end
        if not CanSee(head) then continue end
        if d < bd then bd = d; best = p end
    end
    return best
end

