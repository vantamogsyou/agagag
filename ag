        InfRangeActive = not InfRangeActive
    end
end)

-- ============================================================================
-- 0 SPREAD
-- ============================================================================
local spreadMods = wm["Spread Modifiers"] or {}
if spreadMods["Enabled"] then
    local oldRandom
    pcall(function()
        oldRandom = hookfunction(math.random, function(...)
            if checkcaller() then return oldRandom(...) end
            local a = {...}
            if #a == 0 or (a[1] == -0.05 and a[2] == 0.05) or a[1] == -0.1 or a[1] == -0.05 then
                local amt = (spreadMods["Amount"] or 0) / 100
                return oldRandom(...) * amt
            end
            return oldRandom(...)
        end)
    end)
end

