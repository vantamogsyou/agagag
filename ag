-- SILENT AIM
-- ============================================================================
local function GetSilentAimData()
    if not sa["Enabled"] then return nil end
    local target
    if IS_ACCURACY then
        target = SelectedTarget or CurrentTarget
        if not target or not target.Character then return nil end
        if PlayerDead(target) or PlayerKnocked(target) then return nil end
        local mp   = UserInputService:GetMouseLocation()
        local part = GetTargetPart(target.Character, mp) or target.Character:FindFirstChild("HumanoidRootPart")
        if not part then return nil end
        local vel  = part.AssemblyLinearVelocity or part.Velocity or V3(0,0,0)
        local pred = sa["Prediction"] or {}
        local pos  = part.Position + V3(vel.X*(pred["X"] or 0), vel.Y*(pred["Y"] or 0), vel.Z*(pred["Z"] or 0))
        return part, pos
    else
        if not SilentAimActive then return nil end
        if not CurrentTarget or not CurrentTarget.Character then return nil end
        if PlayerDead(CurrentTarget) or PlayerKnocked(CurrentTarget) then return nil end
        local mp   = UserInputService:GetMouseLocation()
        local part = GetTargetPart(CurrentTarget.Character, mp) or CurrentTarget.Character:FindFirstChild("HumanoidRootPart")
        if not part then return nil end
        return part, GetPredicted(part, CurrentTarget.Character)
    end
end

local grm      = getrawmetatable(game)
local oldIndex = grm.__index
setreadonly(grm, false)
grm.__index = function(self, key)
    if not checkcaller() and self == Mouse then
        local part, pos = GetSilentAimData()
        if part and pos then
            local dir = (pos - Camera.CFrame.Position).Unit
            if key == "Hit"     then return CF(pos, pos + dir)
            elseif key == "Target"  then return part
            elseif key == "UnitRay" then return Ray.new(Camera.CFrame.Position, dir)
            elseif key == "Origin"  then return Camera.CFrame.Position end
        end
    end
    return oldIndex(self, key)
end
setreadonly(grm, true)

local function ShouldRedirect()
    if not sa["Enabled"] then return false end
    if IS_ACCURACY then
        local fb = SelectedTarget or CurrentTarget
        return fb and fb.Character and not PlayerDead(fb) and not PlayerKnocked(fb)
    end
    if not SilentAimActive or not CurrentTarget or not CurrentTarget.Character then return false end
    return not PlayerDead(CurrentTarget) and not PlayerKnocked(CurrentTarget)
end

local function RedirectedRay(ray)
    local _, pos = GetSilentAimData(); if not pos then return ray end
    return Ray.new(ray.Origin, (pos - ray.Origin).Unit * ray.Direction.Magnitude)
end

local oldFPOR, oldFPORWI, oldRC
pcall(function()
    oldFPOR = hookfunction(Workspace.FindPartOnRay, function(self, ray, ...)
        if not checkcaller() and ShouldRedirect() then ray = RedirectedRay(ray) end
        return oldFPOR(self, ray, ...)
    end)
end)
pcall(function()
    oldFPORWI = hookfunction(Workspace.FindPartOnRayWithIgnoreList, function(self, ray, il, ...)
        if not checkcaller() and ShouldRedirect() then ray = RedirectedRay(ray) end
        return oldFPORWI(self, ray, il, ...)
    end)
end)
pcall(function()
    oldRC = hookfunction(Workspace.Raycast, function(self, origin, dir, params)
        if not checkcaller() and ShouldRedirect() then
            if (origin - Camera.CFrame.Position).Magnitude < 15 then
                local _, pos = GetSilentAimData()
                if pos then
                    local nd = pos - origin
                    dir = nd.Unit * max(dir.Magnitude, nd.Magnitude)
                end
            end
        end
        return oldRC(self, origin, dir, params)
    end)
end)
pcall(function()
    local RS = game:GetService("ReplicatedStorage")
    local GH = require(RS.Modules.GunHandler)
    local orig = GH.getAim
    GH.getAim = function(origin, range)
        if sa["Enabled"] and ShouldRedirect() then
            local _, pos = GetSilentAimData()
            if pos then
                local dir = pos - origin
                return dir.Unit, math.min(dir.Magnitude, range)
            end
        end
        return orig(origin, range)
    end
end)

-- ============================================================================
-- TARGET LOOP
-- ============================================================================
local function UpdateTarget()
    if not SilentAimActive or IsChatOpen() then
        if sa["Selection"] == "Automatic" then CurrentTarget = nil end
        return
    end
    if sa["Selection"] == "Target" then
        if SelectedTarget then
            if not SelectedTarget.Character or PlayerDead(SelectedTarget) or PlayerKnocked(SelectedTarget) then
                SelectedTarget = nil; CurrentTarget = nil; SilentAimActive = false
            else CurrentTarget = SelectedTarget end
        else CurrentTarget = nil end
    else
        if sa["StickyAim"] and CurrentTarget then
            if CurrentTarget.Character and not PlayerDead(CurrentTarget) and not PlayerKnocked(CurrentTarget) then return end
            CurrentTarget = nil
        end
        CurrentTarget = FindClosestToMouse()
    end
end

